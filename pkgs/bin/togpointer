#!/usr/bin/env bash
# ONLY_LINUX
wlrctl pointer move 10000 -10000
exit 0

# FIXME
pad=$(xinput list | sed -En '/Touchpad/s/.*id=([0-9]+).*/\1/p')

if [[ -z $1 ]];then
  if [[ $(xinput list-props "$pad" | grep 'Device Enabled' | grep ':\s*0') ]];then
    state=on
  else
    state=off
  fi
else
  state=$1
fi

if [[ $state == on ]];then
  xinput enable "$pad"
elif [[ $state == off ]];then
  wlrctl pointer move 10000 -10000
  xinput disable "$pad"
else
  echo invalid touchpad state
  exit 1
fi
